[Unit]
Description=JARVIS OS Memory Service
Documentation=https://github.com/jarvis-os
After=network.target

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis/backend
ExecStart=/usr/bin/python -m app.memory.store
Restart=on-failure
RestartSec=5

[Install]
WantedBy=jarvis.target
