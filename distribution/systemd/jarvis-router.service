[Unit]
Description=JARVIS OS Meta Router Service
Documentation=https://github.com/jarvis-os
After=jarvis-api.service
BindsTo=jarvis-api.service

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis/backend
ExecStart=/usr/bin/python -m app.router.meta_router
Restart=on-failure
RestartSec=5

[Install]
WantedBy=jarvis.target
