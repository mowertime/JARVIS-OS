[Unit]
Description=JARVIS OS Voice Service
Documentation=https://github.com/jarvis-os
After=network.target sound.target
BindsTo=jarvis-api.service

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis/frontend
Environment=PYTHONPATH=/opt/jarvis/frontend
ExecStart=/usr/bin/python -m voice.voice_service
Restart=on-failure
RestartSec=5

[Install]
WantedBy=jarvis.target
